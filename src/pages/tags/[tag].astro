---
/**
 * Dynamic Tag Pages
 *
 * Filters and displays articles, events, and docs by tag
 */

import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { publishedFilter } from '../../utils/content';

export async function getStaticPaths() {
  const articles = await getCollection('articles', publishedFilter);
  const events = await getCollection('events');
  const docs = await getCollection('docs');

  type Article = (typeof articles)[number];
  type Event = (typeof events)[number];
  type Doc = (typeof docs)[number];

  // Collect all unique tags across all content types
  const allTags = [
    ...new Set([
      ...articles.flatMap((a: Article) => a.data.tags ?? []),
      ...events.flatMap((e: Event) => e.data.tags ?? []),
      ...docs.flatMap((d: Doc) => d.data.tags ?? []),
    ]),
  ];

  return allTags.map((tag) => {
    const filteredArticles = articles
      .filter((a: Article) => a.data.tags?.includes(tag))
      .sort(
        (a: Article, b: Article) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)
      );

    const filteredEvents = events
      .filter((e: Event) => e.data.tags?.includes(tag))
      .sort(
        (a: Event, b: Event) =>
          (b.data.startDate?.getTime() ?? 0) - (a.data.startDate?.getTime() ?? 0)
      );

    const filteredDocs = docs
      .filter((d: Doc) => d.data.tags?.includes(tag))
      .sort((a: Doc, b: Doc) => a.data.title.localeCompare(b.data.title));

    return {
      params: { tag },
      props: { articles: filteredArticles, events: filteredEvents, docs: filteredDocs, tag },
    };
  });
}

const { articles, events, docs, tag } = Astro.props;
const totalCount = articles.length + events.length + docs.length;
---

<PageLayout title={`Tagged "${tag}"`} description={`Browse content about ${tag}`}>
  <div class="region">
    <div class="wrapper">
      <div class="stack-8">
        <!-- Page Header -->
        <header class="center text-center">
          <div class="stack-4">
            <p
              class="text-sm text-muted"
              style="text-transform: uppercase; letter-spacing: var(--tracking-wide);"
            >
              Tag
            </p>
            <h1>{tag}</h1>
            <p class="lead mx-auto">
              {totalCount}
              {totalCount === 1 ? 'item' : 'items'} tagged with "{tag}"
            </p>
            <a href="/tags" class="text-sm">← All tags</a>
          </div>
        </header>

        <!-- Articles -->
        {
          articles.length > 0 && (
            <section class="stack-4">
              {(events.length > 0 || docs.length > 0) && <h2 class="text-xl">Articles</h2>}
              <div class="stack-8">
                {articles.map((article: (typeof articles)[number]) => (
                  <article class="card" data-variant="interactive">
                    <div class="card__header">
                      <h2 class="card__title">
                        <a
                          href={`/articles/${article.id.replace(/\.md$/, '').replace(/\/index$/, '')}`}
                          style="text-decoration: none; color: inherit;"
                        >
                          {article.data.title}
                        </a>
                      </h2>
                      {article.data.description && (
                        <p class="card__description">{article.data.description}</p>
                      )}
                    </div>
                    <div class="card__content">
                      <div class="cluster">
                        {article.data.date && (
                          <time
                            class="text-sm text-muted"
                            datetime={article.data.date.toISOString()}
                          >
                            {article.data.date.toLocaleDateString('en-US', {
                              year: 'numeric',
                              month: 'long',
                              day: 'numeric',
                            })}
                          </time>
                        )}
                        <span class="type-badge" data-type="article">
                          Article
                        </span>
                      </div>
                    </div>
                    {article.data.tags?.length > 0 && (
                      <div class="card__footer">
                        <ul class="tag-list">
                          {article.data.tags.map((articleTag: string) => (
                            <li>
                              <a
                                href={`/tags/${encodeURIComponent(articleTag)}`}
                                class="tag"
                                data-active={articleTag === tag}
                              >
                                {articleTag}
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                  </article>
                ))}
              </div>
            </section>
          )
        }

        <!-- Events -->
        {
          events.length > 0 && (
            <section class="stack-4">
              {(articles.length > 0 || docs.length > 0) && <h2 class="text-xl">Events</h2>}
              <div class="stack-8">
                {events.map((event: (typeof events)[number]) => (
                  <article class="card" data-variant="interactive">
                    <div class="card__header">
                      <h2 class="card__title">
                        <a
                          href={`/events/${event.id.replace(/\.md$/, '').replace(/\/index$/, '')}`}
                          style="text-decoration: none; color: inherit;"
                        >
                          {event.data.title}
                        </a>
                      </h2>
                      {event.data.description && (
                        <p class="card__description">{event.data.description}</p>
                      )}
                    </div>
                    <div class="card__content">
                      <div class="cluster">
                        {event.data.startDate && (
                          <time
                            class="text-sm text-muted"
                            datetime={event.data.startDate.toISOString()}
                          >
                            {event.data.startDate.toLocaleDateString('en-US', {
                              year: 'numeric',
                              month: 'long',
                              day: 'numeric',
                            })}
                          </time>
                        )}
                        <span class="type-badge" data-type="event">
                          Event
                        </span>
                      </div>
                    </div>
                    {event.data.tags?.length > 0 && (
                      <div class="card__footer">
                        <ul class="tag-list">
                          {event.data.tags.map((eventTag: string) => (
                            <li>
                              <a
                                href={`/tags/${encodeURIComponent(eventTag)}`}
                                class="tag"
                                data-active={eventTag === tag}
                              >
                                {eventTag}
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                  </article>
                ))}
              </div>
            </section>
          )
        }

        <!-- Docs -->
        {
          docs.length > 0 && (
            <section class="stack-4">
              {(articles.length > 0 || events.length > 0) && <h2 class="text-xl">Documentation</h2>}
              <div class="stack-8">
                {docs.map((doc: (typeof docs)[number]) => (
                  <article class="card" data-variant="interactive">
                    <div class="card__header">
                      <h2 class="card__title">
                        <a
                          href={`/docs/${doc.id.replace(/\.md$/, '').replace(/\/index$/, '')}`}
                          style="text-decoration: none; color: inherit;"
                        >
                          {doc.data.title}
                        </a>
                      </h2>
                      {doc.data.description && (
                        <p class="card__description">{doc.data.description}</p>
                      )}
                    </div>
                    <div class="card__content">
                      <div class="cluster">
                        <span class="type-badge" data-type="doc">
                          Doc
                        </span>
                      </div>
                    </div>
                    {doc.data.tags?.length > 0 && (
                      <div class="card__footer">
                        <ul class="tag-list">
                          {doc.data.tags.map((docTag: string) => (
                            <li>
                              <a
                                href={`/tags/${encodeURIComponent(docTag)}`}
                                class="tag"
                                data-active={docTag === tag}
                              >
                                {docTag}
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                  </article>
                ))}
              </div>
            </section>
          )
        }
      </div>
    </div>
  </div>
</PageLayout>

<style>
  .type-badge {
    font-size: var(--text-xs);
    padding: 0.25em 0.75em;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .type-badge[data-type='article'] {
    background-color: oklch(90% 0.05 220);
    color: oklch(30% 0.08 220);
  }

  .type-badge[data-type='event'] {
    background-color: oklch(90% 0.05 300);
    color: oklch(30% 0.08 300);
  }

  .type-badge[data-type='doc'] {
    background-color: oklch(90% 0.05 150);
    color: oklch(30% 0.08 150);
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme='light']) .type-badge[data-type='article'] {
      background-color: oklch(25% 0.05 220);
      color: oklch(80% 0.08 220);
    }

    :root:not([data-theme='light']) .type-badge[data-type='event'] {
      background-color: oklch(25% 0.05 300);
      color: oklch(80% 0.08 300);
    }

    :root:not([data-theme='light']) .type-badge[data-type='doc'] {
      background-color: oklch(25% 0.05 150);
      color: oklch(80% 0.08 150);
    }
  }

  :root[data-theme='dark'] .type-badge[data-type='article'] {
    background-color: oklch(25% 0.05 220);
    color: oklch(80% 0.08 220);
  }

  :root[data-theme='dark'] .type-badge[data-type='event'] {
    background-color: oklch(25% 0.05 300);
    color: oklch(80% 0.08 300);
  }

  :root[data-theme='dark'] .type-badge[data-type='doc'] {
    background-color: oklch(25% 0.05 150);
    color: oklch(80% 0.08 150);
  }

  .tag[data-active='true'] {
    background-color: var(--color-accent);
    color: var(--color-white);
    border-color: var(--color-accent);
  }
</style>
