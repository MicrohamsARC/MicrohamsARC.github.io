---
/**
 * Dynamic Article Pages
 *
 * Generates individual pages for each article
 */

import { getCollection, render, type CollectionEntry } from 'astro:content';
import MarkdownLayout from '../../layouts/MarkdownLayout.astro';
import { publishedFilter } from '../../utils/content';

export async function getStaticPaths() {
  const articles = await getCollection('articles', publishedFilter);
  type Article = (typeof articles)[number];

  return articles.map((article: Article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

type Props = {
  article: CollectionEntry<'articles'>;
};

const { article }: Props = Astro.props;
const { Content } = await render(article);
---

<MarkdownLayout frontmatter={article.data}>
  <Content />
</MarkdownLayout>
