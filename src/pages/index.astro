---
/**
 * Homepage - MicroHAMS
 *
 * Bento composition: a featured-event hero paired with a quick-fact rail,
 * then a ranked article column beside a quiet "explore" rail. One 12-col
 * grid per band, no full-width dividers — space and surface do the work.
 */

import PageLayout from '../layouts/PageLayout.astro';
import EventCard from '../components/event/EventCard.astro';
import EventDateTime from '../components/event/EventDateTime.astro';
import { getCollection } from 'astro:content';
import { publishedFilter } from '../utils/content';
import { getEventStartMs, getEventEndMs } from '../utils/event-time';

// Get all published articles, sorted by date (newest first)
const allArticles = await getCollection('articles', publishedFilter);
type Article = (typeof allArticles)[number];
type Event = (typeof allEvents)[number];

const articles = allArticles.sort(
  (a: Article, b: Article) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)
);

// Get all published events
const allEvents = await getCollection('events', publishedFilter);
const now = new Date();
const nowMs = now.getTime();

// Current: started but not ended
// Sort by end time ascending so short-lived events (tonight's meeting) outrank
// long-running background events (month-long DXpedition). Featured still wins.
const currentEvents = allEvents
  .filter((event: Event) => {
    const start = getEventStartMs(event);
    const end = getEventEndMs(event);
    return start <= nowMs && end >= nowMs;
  })
  .sort((a: Event, b: Event) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return getEventEndMs(a) - getEventEndMs(b);
  });

// Upcoming: not started yet
const upcomingEvents = allEvents
  .filter((event: Event) => getEventStartMs(event) > nowMs)
  .sort((a: Event, b: Event) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return getEventStartMs(a) - getEventStartMs(b);
  });

// Combined for hero selection and rail
const currentAndUpcoming = [...currentEvents, ...upcomingEvents];

// Hero event: prioritize featured current (happening now), then featured upcoming, then soonest overall
// Something happening right now should always outrank a future event
const featuredCurrent = currentEvents.find((e: Event) => e.data.featured);
const featuredUpcoming = upcomingEvents.find((e: Event) => e.data.featured);
const heroEvent = featuredCurrent || featuredUpcoming || currentAndUpcoming[0];

// The soonest upcoming meeting, surfaced as a quick-fact tile — but only when
// it isn't already the hero (no point answering "next meeting" twice).
const nextMeeting = upcomingEvents.find(
  (e: Event) => e.data.eventType === 'meeting' && e !== heroEvent
);

// Anything else current/upcoming, for the rail's running list
const railEvents = currentAndUpcoming
  .filter((e: Event) => e !== heroEvent && e !== nextMeeting)
  .slice(0, 2);

// Don't surface an article about the very event we're already featuring as
// the hero (e.g. the Field Day write-up while Field Day is the hero tile).
const heroPrimaryTag = heroEvent?.data.tags?.[0]?.toLowerCase();
const homeArticles = (
  heroPrimaryTag
    ? articles.filter(
        (a: Article) => !(a.data.tags ?? []).some((t: string) => t.toLowerCase() === heroPrimaryTag)
      )
    : articles
).slice(0, 4);

// Calendar dates render in UTC so a midnight date doesn't shift a day in Pacific
const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
---

<PageLayout title="Home" description="MicroHAMS - Amateur Radio Community and Resources">
  <section class="region">
    <div class="wrapper">
      <div class="stack-16">
        {/* ===== Band 1 — What's happening ===== */}
        <div class="modular-grid grid--gap-lg">
          {/* Hero / featured event */}
          <div class="span-8">
            {
              heroEvent ? (
                <EventCard event={heroEvent} variant="featured" />
              ) : (
                <div class="stack-4">
                  <h1 class="text-5xl">
                    Amateur Radio
                    <br />
                    Community &amp; Resources
                  </h1>
                  <p class="lead">
                    Technical articles, projects, documentation, and community events for amateur
                    radio enthusiasts in the Puget Sound area.
                  </p>
                </div>
              )
            }
          </div>

          {/* Rail: next meeting + running list */}
          <div class="span-4 stack-6">
            {
              nextMeeting && (
                <aside class="box box--lg box--bordered stack-3">
                  <p class="eyebrow">Next Meeting</p>
                  <p class="text-lg font-medium">{nextMeeting.data.title}</p>
                  <EventDateTime
                    eventDate={nextMeeting.data.eventDate}
                    endDate={nextMeeting.data.endDate}
                    startTime={nextMeeting.data.startTime}
                    endTime={nextMeeting.data.endTime}
                    venue={nextMeeting.data.venue}
                    timezone={nextMeeting.data.timezone}
                    class="text-sm text-muted"
                  />
                  <a href={`/events/${nextMeeting.id}`} class="font-medium">
                    Details &amp; how to join →
                  </a>
                </aside>
              )
            }

            {
              railEvents.length > 0 && (
                <div class="stack-3">
                  <h2 class="eyebrow">Current &amp; Upcoming</h2>
                  {railEvents.map((event) => (
                    <EventCard event={event} variant="horizontal" showDescription={false} />
                  ))}
                </div>
              )
            }

            <a href="/events" class="font-medium">Full calendar →</a>
          </div>
        </div>

        {/* ===== Band 2 — Read + explore ===== */}
        {
          homeArticles.length > 0 && (
            <div class="modular-grid grid--gap-xl">
              {/* Latest articles — each a bounded card */}
              <div class="span-8 stack-6 reveal">
                <h2 class="eyebrow">Latest</h2>

                <div class="grid grid--auto-fit grid--min-wide grid--gap-lg">
                  {homeArticles.map((article: Article) => (
                    <article class="card stack-3">
                      {article.data.tags?.[0] && <span class="badge">{article.data.tags[0]}</span>}
                      <h3 class="text-xl">
                        <a href={`/articles/${article.id}`} class="link-plain">
                          {article.data.title}
                        </a>
                      </h3>
                      {article.data.description && (
                        <p class="text-muted text-sm">{article.data.description}</p>
                      )}
                      {article.data.date && (
                        <time
                          class="text-sm text-subtle"
                          datetime={article.data.date.toISOString()}
                        >
                          {fmtDate(article.data.date)}
                        </time>
                      )}
                    </article>
                  ))}
                </div>

                <div>
                  <a href="/articles" class="font-medium">
                    All Articles →
                  </a>
                </div>
              </div>

              {/* Explore rail — About + Docs only. Events already lives in the
                  nav and the calendar link above, so it isn't repeated here. */}
              <aside class="span-4 reveal">
                <div class="box box--lg box--surface-muted stack-8">
                  <div class="stack-2">
                    <h3 class="text-xl">About MicroHAMS</h3>
                    <p class="text-muted text-sm">
                      A dynamic organization of amateur radio enthusiasts in the Puget Sound area,
                      dedicated to hands-on experimentation.
                    </p>
                    <a href="/about" class="font-medium">
                      Learn more →
                    </a>
                  </div>
                  <div class="stack-2">
                    <h3 class="text-xl">Documentation</h3>
                    <p class="text-muted text-sm">
                      Technical guides and reference for operators of all skill levels.
                    </p>
                    <a href="/docs" class="font-medium">
                      Browse docs →
                    </a>
                  </div>
                </div>
              </aside>
            </div>
          )
        }
      </div>
    </div>
  </section>
</PageLayout>
