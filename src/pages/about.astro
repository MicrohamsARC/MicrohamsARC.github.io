---
/**
 * About Page - MicroHAMS
 *
 * Direct route for the about page from pages collection
 */

import MarkdownLayout from '../layouts/MarkdownLayout.astro';
import { loadRenderedPageEntry } from '../utils/page-entry';

const page = await loadRenderedPageEntry('about');

if (!page) {
  return new Response(null, {
    status: 404,
    statusText: 'Not found',
  });
}
const { frontmatter, Content, headings } = page;
---

<MarkdownLayout frontmatter={frontmatter} headings={headings}>
  <Content />
</MarkdownLayout>
