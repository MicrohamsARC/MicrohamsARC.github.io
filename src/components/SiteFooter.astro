---
/**
 * Site Footer - Global Footer
 */
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrapper">
    <div class="site-footer__inner">
      <p class="site-footer__brand">
        <span class="font-semibold">MicroHAMS</span>
        <span class="site-footer__sep" aria-hidden="true">·</span>
        <span class="text-muted">Amateur Radio Community</span>
      </p>

      <div class="site-footer__end text-sm">
        <nav class="site-footer__links" aria-label="Footer">
          <a href="/about#location--contact">Contact</a>
          <a href="https://github.com/MicrohamsARC/MicrohamsARC.github.io/issues">GitHub</a>
        </nav>
        <span class="site-footer__copy text-xs text-muted">© {year} MicroHAMS</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3) var(--space-8);
  }

  .site-footer__brand {
    margin: 0;
  }

  .site-footer__sep {
    margin-inline: var(--space-2);
    color: var(--color-text-subtle);
  }

  .site-footer__end {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-6);
  }

  .site-footer__links {
    display: flex;
    gap: var(--space-5);
  }
</style>
